# Copy this file to ".env" and fill in your values.

# ── Bot Token (get from @BotFather on Telegram) ────────────────────
BOT_TOKEN=put-your-token-here

# ── Telegram API credentials (get from https://my.telegram.org) ────
# Required for downloader.py and uploader.py (user-account scripts)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── Video storage ──────────────────────────────────────────────────
# Folder containing downloaded video files.
MEDIA_DIR=./media

# Private Telegram channel ID where videos are uploaded for forwarding.
# Set this after running uploader.py (it prints the channel ID).
STORAGE_CHANNEL_ID=

# ── Source bot (for the downloader) ────────────────────────────────
SOURCE_BOT=OnePiece_MMSub_s1_bot

# ── Episode settings ──────────────────────────────────────────────
# Episodes per range button (reference bot uses 25)
RANGE_SIZE=25

# Total episodes (0 = auto-detect from manifest)
TOTAL_EPISODES=0

# ── Access control ────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone. Get your ID from @userinfobot.
ALLOWED_USER_IDS=

# ── Web dashboard (web_app.py — multi-tenant session manager) ─────
# Port the FastAPI app listens on (nginx proxies to this).
PORT=8080
# Set "true" in production (HTTPS) so the session cookie is Secure.
# Set "false" for local http testing, otherwise the browser drops the cookie.
COOKIE_SECURE=true
# Where per-user .session files are stored.
SESSIONS_DIR=sessions
# Disconnect idle clients (no open WebSocket) after this many seconds.
IDLE_TIMEOUT=1800

# ── Operator / Admin console ──────────────────────────────────────
# App-level operator who can see ALL logged-in accounts and read/manage
# every chat. Leave ADMIN_PASSWORD empty to DISABLE the operator console.
# Use an alphanumeric/dash password (the deploy script writes it shell-safely).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Optional: override the admin cookie-signing secret. If unset it derives from
# TELEGRAM_API_HASH + ADMIN_PASSWORD (so changing the password logs operators out).
ADMIN_SECRET=

# ── MLBB top-up (DK shop supplier hub) ────────────────────────────
# Player-name lookup + diamond packages + orders go through this hub.
MLBB_HUB_URL=https://root.dkgamingshop.com/api
MLBB_HUB_KEY=

# ── MLBB top-up bot (customer-facing, bot-scoped) ─────────────────
# BotFather token for the top-up bot. Customers chat the bot directly
# (no Telegram account login). Empty => bot disabled.
TELEGRAM_TOPUP_BOT_TOKEN=
# DANGER: true lets the bot place REAL smile.one orders (debits your balance,
# no payment collected at the hub). Leave false until payment is wired.
TOPUP_ORDERS_ENABLED=false

# ── Legacy settings ──────────────────────────────────────────────
PAGE_SIZE=8

# ── Telegram Stars Top-up (via DK Shop Hub) ───────────────────────────────
TELEGRAM_STARS_50_ITEM_ID=50_stars_item_id
